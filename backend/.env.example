# Backend environment variables (example)

# Core
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/tail-treasures
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me
CLIENT_URL=http://localhost:3000

# If deploying behind a reverse proxy (Render, etc.) set this to 1
TRUST_PROXY=

# Optional: allow Vercel preview domains (*.vercel.app) in CORS.
# Keep this false unless you need previews to call your API.
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# Redis caching (optional; API still works if disabled)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# Cloudinary uploads (optional; recommended for Render since local disk is ephemeral)
# If enabled + configured, uploaded images are stored as Cloudinary HTTPS URLs.
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Base folder in your Cloudinary media library
CLOUDINARY_FOLDER=tail-treasures

# Solr search (optional; /api/search falls back to MongoDB when disabled)
SOLR_ENABLED=false
SOLR_URL=http://localhost:8983/solr/tailwaggers

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
OAUTH_REDIRECT_PATH=/oauth/callback

# Optional: force OAuth cookie secure flag.
# Leave empty to auto-detect HTTPS via req.secure / x-forwarded-proto.
OAUTH_COOKIE_SECURE=

# B2B partner API key (required only for /api/partner/* endpoints)
PARTNER_API_KEY=change-me-to-a-random-string

# Swagger server list (optional)
# PUBLIC_API_URL=https://your-deployed-api.example.com
