{
  "name": "tail-treasures-backend",
  "version": "1.0.0",
  "description": "Backend API for Tail Treasures Pet Care and Adoption Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --coverage",
    "benchmark:redis-off": "node scripts/runBenchmarks.js --redis=off",
    "benchmark:redis-on": "node scripts/runBenchmarks.js --redis=on",
    "benchmark:all": "node scripts/runBenchmarks.js --redis=both"
  },
  "keywords": [
    "pet",
    "adoption",
    "veterinary",
    "ecommerce"
  ],
  "author": "Tail Treasures Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "connect-mongo": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.17.3",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "artillery": "^2.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^9.1.8",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
